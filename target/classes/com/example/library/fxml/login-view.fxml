<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.library.controller.AuthController"
      alignment="CENTER" spacing="16"
      style="-fx-padding: 40; -fx-background-color: #f4f4f4;">
    <Label text="Library Management System" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="Login to continue" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
    <VBox spacing="6" maxWidth="300">
        <Label text="Username"/>
        <TextField fx:id="txtUsername" promptText="Enter username"/>
    </VBox>
    <VBox spacing="6" maxWidth="300">
        <Label text="Password"/>
        <PasswordField fx:id="txtPassword" promptText="Enter password"/>
    </VBox>
    <Button text="Login" onAction="#handleLogin" maxWidth="300"
            style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 13px; -fx-pref-height: 36px;"/>
    <HBox alignment="CENTER" spacing="6">
        <Label text="No account yet?"/>
        <Hyperlink text="Sign Up" onAction="#handleSignUp"/>
    </HBox>
</VBox>
